{
  "name": "pi-coder-theme",
  "version": "0.2.0",
  "description": "Pi Coder Theme UI suite for Pi: theme, editor chrome, and compact tool display.",
  "keywords": [
    "pi-package",
    "pi-theme",
    "pi-extension",
    "pi-coding-agent",
    "pi-coder-theme",
    "tui",
    "tool-rendering"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "extensions",
    "themes",
    "skills",
    "screenshots"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pi --no-extensions --no-themes -e . -p 'Reply with ok'",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run typecheck && npm test && npm run check && npm run pack:check"
  },
  "pi": {
    "extensions": [
      "./node_modules/@marckrenn/pi-sub-core/index.ts",
      "./extensions/pi-coder-theme-editor.ts",
      "./extensions/thinking-steps/index.ts",
      "./node_modules/pi-tool-display/index.ts",
      "./extensions/pi-coder-theme-user-message.ts"
    ],
    "themes": [
      "./themes"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@marckrenn/pi-sub-core": "^1.5.0",
    "@sinclair/typebox": "^0.34.49",
    "pi-tool-display": "^0.3.3"
  },
  "bundledDependencies": [
    "pi-tool-display"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@types/node": "^24.12.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  }
}
